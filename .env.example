# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_EVENTS=ecommerce.events.raw
KAFKA_TOPIC_FEATURES=ecommerce.features.computed
KAFKA_TOPIC_ALERTS=ecommerce.alerts.drift
KAFKA_TOPIC_REFRESH=ecommerce.features.refresh
KAFKA_CONSUMER_GROUP=feature-processor-cg

# ── Spark ────────────────────────────────────────────────────────────────────
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_CHECKPOINT_DIR=/tmp/spark-checkpoints
DELTA_TABLE_PATH=/data/feature_store

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20
FEATURE_TTL_SECONDS=300

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=feature_store
AIRFLOW_DB=airflow
POSTGRES_USER=featurestore
POSTGRES_PASSWORD=featurestore_secret

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Airflow ──────────────────────────────────────────────────────────────────
AIRFLOW_FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
AIRFLOW_SECRET_KEY=secret

# ── Application ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
EVENT_RATE_TPS=100
CONSISTENCY_THRESHOLD=0.01
PSI_WARN_THRESHOLD=0.1
PSI_ALERT_THRESHOLD=0.2
API_PORT=8000
STREAMLIT_PORT=8501
ENVIRONMENT=development
